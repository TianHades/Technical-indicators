# Trade Sentry 配置模板
# 复制为 .env 并填入你的配置:  cp .env.sample .env

# ── LLM 提供商 ───────────────────────────────────────
# 可选: deepseek (默认) / anthropic / openai
# 不设置则自动检测（有哪个 Key 就用哪个）
# TRADE_SENTRY_LLM_PROVIDER=deepseek

# ── DeepSeek ─────────────────────────────────────────
# 注册获取 Key: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key
# 模型默认 deepseek-v4-pro，无需修改
# TRADE_SENTRY_MODEL=deepseek-v4-pro

# ── Anthropic (备选) ─────────────────────────────────
# 获取 Key: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key
# TRADE_SENTRY_MODEL=claude-sonnet-4-6
# TRADE_SENTRY_API_BASE=https://api.anthropic.com

# ── OpenAI / 中转 (备选) ─────────────────────────────
# OPENAI_API_KEY=sk-your-key
# TRADE_SENTRY_API_BASE=https://api.openai.com/v1
# TRADE_SENTRY_MODEL=gpt-4o

# ── Tushare Token (可选) ─────────────────────────────
# 注册获取: https://tushare.pro
# TUSHARE_TOKEN=your-token

# ── 飞书机器人 (可选) ─────────────────────────────────
# 从飞书开放平台获取: https://open.feishu.cn
# 进入应用 → 事件订阅 → 获取 Verification Token
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_VERIFICATION_TOKEN=xxx
